# Secrets and runtime config for BILBO. Copy to .env (gitignored) and fill in.
# Inside Docker, docker-compose feeds this into every container via env_file.
# On the host, monitor.py / cli.py read it via config.load_env(ENV_FILE).

# ---- RTSP camera ----
# URL the capture container uses to grab frames. Use the camera's LAN IP, not
# host.docker.internal, since capture is on host-network mode for RTSP to work.
RTSP_STREAM_URL=rtsp://user:password@camera.local:554/stream

# ---- Cloud vision fallback (BIRDEYE escapes ~1% of frames to this) ----
OPENAI_API_KEY=sk-...
# Optional Claude-as-backup model for the cloud chain (rarely exercised).
ANTHROPIC_API_KEY=

# ---- Telegram alerts (wake/asleep/safety/watchdog) ----
# Bot created via @BotFather. Chat ID is the destination user/group.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Cloudflare Access service token (only needed if the dashboard is
# fronted by Cloudflare Access). Injected into the PWA service worker so
# the installed app keeps reaching /api/* after the SSO cookie expires.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# ---- control-api -> capture URL ----
# control-api dials capture's /infer endpoint. Capture is on host-network
# mode (so RTSP works), so it doesn't resolve as `capture:5557` on the
# bridge network. Pick the value that matches your host:
#   Linux production:    http://host.docker.internal:5557  (works via extra_hosts: host-gateway)
#   macOS Docker Desktop: http://192.168.65.3:5557          (the Docker VM IP)
BILBO_CAPTURE_URL=http://host.docker.internal:5557

# ---- Postgres (single source of truth) ----
# The compose stack runs its own postgres:16 container with a named volume.
# To change the DB password, set POSTGRES_PASSWORD in your SHELL or in
# deploy/.env (NOT here) — compose substitutes it at parse time into the
# postgres container AND the DATABASE_URL of every bilbo service, keeping them
# in sync. Defaults to `bilbo` if unset.
#   export POSTGRES_PASSWORD=something-strong
# For host (non-Docker) dev, point DATABASE_URL at your local Postgres:
# DATABASE_URL=postgresql://bilbo:bilbo@localhost:5432/bilbo

# ---- Optional path overrides (defaults assume BILBO_ROOT=/app in Docker
# and the repo root on host dev) ----
# BILBO_ROOT=/custom/install/path
# BILBO_DATA_DIR=/custom/data
# BILBO_MODELS_DIR=/custom/pipeline/models
# BILBO_ENV_FILE=/custom/.env
# BILBO_REFERENCES_DIR=/custom/references
